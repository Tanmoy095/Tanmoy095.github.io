---
const { title } = Astro.props;
import { site } from '../config';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{title || site.title}</title>
    <link rel="stylesheet" href="https://cdn.tailwindcss.com">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
        body { font-family: 'Inter', sans-serif; }
        .gradient-text { background: linear-gradient(135deg, #4f46e5 0%, #ec4899 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    </style>
</head>
<body class="bg-white dark:bg-slate-950 text-slate-900 dark:text-slate-50 transition-colors">
    <header class="sticky top-0 z-50 backdrop-blur border-b border-slate-200 dark:border-slate-800">
        <nav class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
            <a href="/" class="text-2xl font-bold gradient-text">Tanmoy</a>
            <div class="flex gap-8 items-center">
                {site.nav && site.nav.map(item => (
                    <a href={item.url} class="hover:text-indigo-600 dark:hover:text-indigo-400 font-medium">{item.label}</a>
                ))}
            </div>
        </nav>
    </header>

    <main class="max-w-6xl mx-auto px-6 py-12">
        <slot />
    </main>

    <footer class="bg-slate-900 dark:bg-black text-white py-12 mt-20">
        <div class="max-w-6xl mx-auto px-6 text-center">
            <p>&copy; 2026 {site.author}. All rights reserved.</p>
            <p class="text-slate-400 mt-2">{site.email} | {site.phone}</p>
        </div>
    </footer>
</body>
</html>
