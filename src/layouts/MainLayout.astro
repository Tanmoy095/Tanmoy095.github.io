---
const { title, description } = Astro.props;
import profile from '../data/profile.json';
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{title ? `${title} | ${profile.name}` : `${profile.name} - ${profile.title}`}</title>
    <meta name="description" content={description || profile.summary}>
    
    <!-- SEO Meta tags -->
    <meta property="og:title" content={title || profile.name} />
    <meta property="og:description" content={description || profile.summary} />
    <meta property="og:type" content="website" />
    
    <!-- Modern Typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <!-- Inline Tailwind Config for Custom Colors & Styles -->
    <style is:global>
        body {
            font-family: 'Inter', sans-serif;
        }
        h1, h2, h3, h4, h5, h6 {
            font-family: 'Outfit', sans-serif;
        }
        .gradient-text {
            background: linear-gradient(135deg, #6366f1 0%, #a855f7 50%, #ec4899 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .gradient-bg {
            background: linear-gradient(135deg, #6366f1 0%, #a855f7 50%, #ec4899 100%);
        }
        .glass-header {
            background-color: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(16px);
        }
        .dark .glass-header {
            background-color: rgba(15, 23, 42, 0.7);
            backdrop-filter: blur(16px);
        }
    </style>
    
    <script is:inline>
        // Inline script to prevent theme flash
        const theme = (() => {
            if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
                return localStorage.getItem('theme');
            }
            if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                return 'dark';
            }
            return 'light';
        })();
      
        if (theme === 'dark') {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>
</head>
<body class="bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-slate-50 transition-colors duration-300 min-h-screen flex flex-col">
    <!-- Header -->
    <header class="sticky top-0 z-50 glass-header border-b border-slate-200/50 dark:border-slate-800/50 transition-colors duration-300">
        <nav class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
            <a href="/" class="text-2xl font-bold tracking-tight bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 bg-clip-text text-transparent hover:scale-105 transition-transform duration-200">
                {profile.name.split(' ').pop()}
            </a>
            
            <!-- Desktop Navigation -->
            <div class="hidden md:flex gap-8 items-center">
                {profile.nav.map(item => (
                    <a href={item.url} class="hover:text-indigo-600 dark:hover:text-indigo-400 font-medium tracking-wide transition-colors duration-200 text-sm uppercase">
                        {item.label}
                    </a>
                ))}
                
                <!-- Dark Mode Toggle -->
                <button id="theme-toggle" class="p-2.5 rounded-xl border border-slate-200 dark:border-slate-800 hover:bg-slate-100 dark:hover:bg-slate-900 transition-colors duration-200 focus:outline-none" aria-label="Toggle theme">
                    <svg id="theme-toggle-dark-icon" class="w-4 h-4 hidden" fill="currentColor" viewBox="0 0 20 20"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path></svg>
                    <svg id="theme-toggle-light-icon" class="w-4 h-4 hidden" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.464 5.05l-.707-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 100 2h1z" fill-rule="evenodd" clip-rule="evenodd"></path></svg>
                </button>
            </div>
            
            <!-- Mobile Menu Toggle Button -->
            <div class="flex md:hidden items-center gap-4">
                <button id="mobile-theme-toggle" class="p-2 rounded-xl border border-slate-200 dark:border-slate-800 hover:bg-slate-100 dark:hover:bg-slate-900 transition-colors" aria-label="Toggle theme">
                    <span class="dark:hidden">🌙</span>
                    <span class="hidden dark:inline">☀️</span>
                </button>
                <button id="menu-btn" class="p-2 rounded-xl border border-slate-200 dark:border-slate-800 focus:outline-none" aria-label="Toggle menu">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                </button>
            </div>
        </nav>
        
        <!-- Mobile Dropdown Menu -->
        <div id="mobile-menu" class="hidden md:hidden border-t border-slate-200/50 dark:border-slate-800/50 px-6 py-4 flex flex-col gap-4 bg-white/95 dark:bg-slate-950/95 transition-all duration-300">
            {profile.nav.map(item => (
                <a href={item.url} class="hover:text-indigo-600 dark:hover:text-indigo-400 font-medium tracking-wide py-2 text-sm uppercase">
                    {item.label}
                </a>
            ))}
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow max-w-6xl w-full mx-auto px-6 py-12">
        <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-slate-900 dark:bg-black text-slate-300 dark:text-slate-400 border-t border-slate-800 py-12 mt-auto transition-colors duration-300">
        <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-8 items-center text-center md:text-left">
            <div>
                <p class="font-bold text-white text-lg tracking-wide">{profile.name}</p>
                <p class="text-sm text-slate-400 mt-1">{profile.title}</p>
            </div>
            <div class="flex flex-col md:items-end text-sm gap-2">
                <p>&copy; {new Date().getFullYear()} {profile.name}. All rights reserved.</p>
                <p class="text-slate-500">{profile.email} | {profile.phone}</p>
            </div>
        </div>
    </footer>

    <!-- Theme & Menu Scripts -->
    <script is:inline>
        const themeToggleDarkIcon = document.getElementById('theme-toggle-dark-icon');
        const themeToggleLightIcon = document.getElementById('theme-toggle-light-icon');
        const themeToggleBtn = document.getElementById('theme-toggle');
        const mobileThemeToggle = document.getElementById('mobile-theme-toggle');

        function updateIcons() {
            if (document.documentElement.classList.contains('dark')) {
                themeToggleLightIcon.classList.remove('hidden');
                themeToggleDarkIcon.classList.add('hidden');
            } else {
                themeToggleDarkIcon.classList.remove('hidden');
                themeToggleLightIcon.classList.add('hidden');
            }
        }

        updateIcons();

        function toggleTheme() {
            if (document.documentElement.classList.contains('dark')) {
                document.documentElement.classList.remove('dark');
                localStorage.setItem('theme', 'light');
            } else {
                document.documentElement.classList.add('dark');
                localStorage.setItem('theme', 'dark');
            }
            updateIcons();
        }

        themeToggleBtn.addEventListener('click', toggleTheme);
        mobileThemeToggle.addEventListener('click', toggleTheme);

        // Mobile Menu Toggle
        const menuBtn = document.getElementById('menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        menuBtn.addEventListener('click', () => {
            mobileMenu.classList.toggle('hidden');
        });
    </script>

    <!-- Recruiter AI Assistant -->
    <div id="ai-assistant-container" class="fixed bottom-6 right-6 z-[100] font-sans">
        <!-- Floating Chat Icon -->
        <button id="ai-chat-btn" class="w-14 h-14 rounded-full bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 text-white flex items-center justify-center shadow-2xl hover:scale-105 active:scale-95 transition-all duration-200 focus:outline-none" aria-label="Open AI Assistant">
            <span class="text-2xl">🤖</span>
        </button>

        <!-- Chat Panel -->
        <div id="ai-chat-panel" class="hidden absolute bottom-18 right-0 w-[320px] sm:w-[380px] h-[480px] bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl shadow-2xl flex flex-col overflow-hidden transition-all duration-200">
            <!-- Chat Header -->
            <div class="p-4 bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 text-white flex justify-between items-center">
                <div class="flex items-center gap-2">
                    <span class="text-xl">🤖</span>
                    <div>
                        <h3 class="font-bold text-sm leading-tight">Tanmoy's AI Copilot</h3>
                        <p class="text-[9px] text-indigo-100 font-semibold tracking-wider uppercase">RECRUITER ASSISTANT</p>
                    </div>
                </div>
                <button id="close-chat-btn" class="text-white hover:text-indigo-100 text-sm font-bold font-mono focus:outline-none">✕</button>
            </div>

            <!-- Chat Messages Area -->
            <div id="chat-messages" class="flex-grow p-4 overflow-y-auto space-y-3 bg-slate-50/50 dark:bg-slate-950/20 text-xs">
                <!-- Welcome Message -->
                <div class="flex gap-2 items-start max-w-[85%]">
                    <div class="w-7 h-7 rounded-full bg-indigo-100 dark:bg-indigo-950 flex items-center justify-center text-xs flex-shrink-0">🤖</div>
                    <div class="p-3 bg-white dark:bg-slate-850 rounded-2xl rounded-tl-none border border-slate-100 dark:border-slate-800/80 shadow-sm leading-relaxed text-slate-700 dark:text-slate-200">
                        Hi! I am Tanmoy's AI Platform Assistant. Ask me anything about his Go backend engineering, Kubernetes platform work, or AI gateways!
                    </div>
                </div>
            </div>

            <!-- Quick Suggestions -->
            <div class="p-2.5 border-t border-slate-100 dark:border-slate-800/80 flex flex-wrap gap-1.5 bg-white dark:bg-slate-900">
                <button class="chat-suggest-btn text-[10px] px-2.5 py-1.5 bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl hover:border-indigo-500 hover:text-indigo-600 dark:hover:text-indigo-400 transition text-left text-slate-600 dark:text-slate-400 font-medium" data-q="What are your core technical skills?">🛠️ Skills</button>
                <button class="chat-suggest-btn text-[10px] px-2.5 py-1.5 bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl hover:border-indigo-500 hover:text-indigo-600 dark:hover:text-indigo-400 transition text-left text-slate-600 dark:text-slate-400 font-medium" data-q="Tell me about your LogiFlow AI project.">🚀 LogiFlow AI</button>
                <button class="chat-suggest-btn text-[10px] px-2.5 py-1.5 bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl hover:border-indigo-500 hover:text-indigo-600 dark:hover:text-indigo-400 transition text-left text-slate-600 dark:text-slate-400 font-medium" data-q="Are you open to remote jobs?">💼 Hiring Info</button>
            </div>

            <!-- Input area -->
            <form id="chat-input-form" class="p-2.5 border-t border-slate-200/50 dark:border-slate-800/50 bg-white dark:bg-slate-900 flex gap-2">
                <input type="text" id="chat-input" placeholder="Type a question..." required class="flex-grow bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-850 rounded-xl px-3 py-2 text-xs focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition duration-200" />
                <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl px-3 py-1.5 text-xs font-bold transition">Send</button>
            </form>
        </div>
    </div>

    <!-- AI Bot Logic -->
    <script is:inline>
        (function() {
            const chatBtn = document.getElementById('ai-chat-btn');
            const chatPanel = document.getElementById('ai-chat-panel');
            const closeBtn = document.getElementById('close-chat-btn');
            const chatMessages = document.getElementById('chat-messages');
            const chatForm = document.getElementById('chat-input-form');
            const chatInput = document.getElementById('chat-input');
            const suggestBtns = document.querySelectorAll('.chat-suggest-btn');

            // Toggle Panel
            chatBtn.addEventListener('click', () => {
                chatPanel.classList.toggle('hidden');
                chatInput.focus();
            });

            closeBtn.addEventListener('click', () => {
                chatPanel.classList.add('hidden');
            });

            // Quick suggestions
            suggestBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    const q = btn.getAttribute('data-q');
                    handleUserQuestion(q);
                });
            });

            chatForm.addEventListener('submit', (e) => {
                e.preventDefault();
                const q = chatInput.value.trim();
                if (!q) return;
                chatInput.value = '';
                handleUserQuestion(q);
            });

            function appendMessage(sender, text) {
                const isBot = sender === 'bot';
                const msgWrap = document.createElement('div');
                msgWrap.className = `flex gap-2 items-start ${isBot ? 'max-w-[85%]' : 'max-w-[85%] ml-auto flex-row-reverse'}`;
                
                const avatar = document.createElement('div');
                avatar.className = `w-7 h-7 rounded-full flex items-center justify-center text-xs flex-shrink-0 ${isBot ? 'bg-indigo-100 dark:bg-indigo-950' : 'bg-pink-100 dark:bg-pink-950'}`;
                avatar.textContent = isBot ? '🤖' : '💼';
                
                const msgBox = document.createElement('div');
                msgBox.className = `p-3 rounded-2xl border shadow-sm leading-relaxed ${
                    isBot 
                        ? 'bg-white dark:bg-slate-850 rounded-tl-none border-slate-100 dark:border-slate-800/80 text-slate-700 dark:text-slate-200' 
                        : 'bg-indigo-600 border-indigo-700 text-white rounded-tr-none'
                }`;
                
                msgBox.innerHTML = text.replace(/\n/g, '<br/>');
                msgWrap.appendChild(avatar);
                msgWrap.appendChild(msgBox);
                chatMessages.appendChild(msgWrap);
                chatMessages.scrollTop = chatMessages.scrollHeight;
                return msgBox;
            }

            function simulateTyping(answer, callback) {
                // Show typing indicator
                const indicator = document.createElement('div');
                indicator.className = 'flex gap-2 items-start max-w-[85%] typing-indicator';
                indicator.innerHTML = `
                    <div class="w-7 h-7 rounded-full bg-indigo-100 dark:bg-indigo-950 flex items-center justify-center text-xs flex-shrink-0">🤖</div>
                    <div class="p-3 bg-white dark:bg-slate-850 rounded-2xl rounded-tl-none border border-slate-100 dark:border-slate-800/80 shadow-sm flex items-center gap-1">
                        <span class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay: 0ms"></span>
                        <span class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay: 150ms"></span>
                        <span class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay: 300ms"></span>
                    </div>
                `;
                chatMessages.appendChild(indicator);
                chatMessages.scrollTop = chatMessages.scrollHeight;

                setTimeout(() => {
                    indicator.remove();
                    const box = appendMessage('bot', '');
                    let i = 0;
                    const interval = setInterval(() => {
                        if (i < answer.length) {
                            // handles simple tags/newlines
                            if (answer.slice(i, i + 4) === '<br>') {
                                box.innerHTML += '<br>';
                                i += 4;
                            } else {
                                box.textContent += answer[i];
                                // re-parse newlines to HTML
                                box.innerHTML = box.textContent.replace(/\n/g, '<br/>');
                                i++;
                            }
                            chatMessages.scrollTop = chatMessages.scrollHeight;
                        } else {
                            clearInterval(interval);
                            if (callback) callback();
                        }
                    }, 12);
                }, 800);
            }

            function handleUserQuestion(q) {
                appendMessage('user', q);
                const query = q.toLowerCase();
                let answer = '';

                if (query.includes('skill') || query.includes('experience') || query.includes('expert') || query.includes('tech') || query.includes('stack') || query.includes('language') || query.includes('go') || query.includes('golang')) {
                    answer = "🛠️ Tanmoy is a Senior Go Backend & Platform Engineer with 4+ years of production experience.\n\nHis primary core stacks are:\n• Go (Microservices, gRPC, Domain-Driven Design)\n• Kubernetes operators, controllers, controllers-runtime, CRDs\n• Distributed systems: Kafka, RabbitMQ, Temporal Workflows\n• AI Infrastructure: LLM gateways, semantic caching, pgvector, RAG, and Model Context Protocol (MCP) integrations.";
                } else if (query.includes('logiflow') || query.includes('project') || query.includes('showcase') || query.includes('logisynapse')) {
                    answer = "🚀 Tanmoy's featured project is LogiFlow AI, an enterprise-grade AI Infrastructure & Orchestration platform. It solves standard LLM orchestration challenges with:\n• Dynamic multi-provider routing (OpenAI, Anthropic, local vLLM)\n• Durable agent execution workflows built on Temporal\n• A custom Kubernetes operator for multi-tenant workspace isolation\n• A secure OIDC/JWT OAuth2 server for API key management.";
                } else if (query.includes('job') || query.includes('hire') || query.includes('available') || query.includes('remote') || query.includes('work') || query.includes('availability') || query.includes('recrut')) {
                    answer = "💼 Tanmoy is currently open to full-time remote opportunities, contract roles, or technical consulting engagements.\n\nHe is looking for roles like:\n• Senior Go Backend Engineer\n• Platform / Infrastructure Engineer\n• AI Infrastructure/Platform Engineer\n• Distributed Systems Engineer";
                } else if (query.includes('contact') || query.includes('email') || query.includes('phone') || query.includes('linkedin') || query.includes('github') || query.includes('connect')) {
                    answer = "📞 You can connect with Tanmoy directly:\n• Email: adtanmoy95@gmail.com\n• Phone: +8801850371329\n• LinkedIn: linkedin.com/in/aunmoy-dey-tanmoy095\n• GitHub: github.com/Tanmoy095";
                } else if (query.includes('resume') || query.includes('cv') || query.includes('pdf')) {
                    answer = "📄 You can download Tanmoy's latest resume directly from the homepage or by clicking the link below:\n\n👉 <a href='/cv.pdf' download class='text-indigo-400 font-bold hover:underline'>Download Resume (PDF)</a>";
                } else {
                    answer = "💡 I can answer detailed questions about Tanmoy's Go experience, his Kubernetes operator projects, distributed systems design, or his availability.\n\nTry asking: 'Tell me about LogiFlow AI' or 'What is his Go experience?'";
                }

                simulateTyping(answer);
            }
        })();
    </script>
</body>
</html>
