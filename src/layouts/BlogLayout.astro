---
interface Props {
  title: string;
  date: Date;
  author?: string;
  tags?: string[];
  image?: string;
}

const { title, date, author = 'Your Name', tags = [], image } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <article class="prose dark:prose-invert max-w-3xl mx-auto px-4 py-16">
      <header class="mb-12">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">{title}</h1>
        {image && <img src={image} alt={title} class="rounded-lg mb-6 w-full h-auto object-cover max-h-96" />}
        <div class="flex flex-wrap gap-4 text-slate-600 dark:text-slate-400 mb-4">
          <time datetime={date.toISOString()}>
            {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <span>by {author}</span>
        </div>
        {tags && tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {tags.map(tag => (
              <span class="bg-primary/10 text-primary px-3 py-1 rounded-full text-sm">
                #{tag}
              </span>
            ))}
          </div>
        )}
      </header>
      <slot />
    </article>
  </body>
</html>
