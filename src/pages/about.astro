---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="About Me - AI Infrastructure Engineer">
    <div class="py-12">
        <h1 class="text-5xl font-bold gradient-text mb-8">About Me</h1>
        
        <div class="grid md:grid-cols-3 gap-8 mb-12">
            <div class="text-center">
                <div class="text-4xl font-bold text-indigo-600">6+</div>
                <p class="text-slate-600 dark:text-slate-400">Years of Experience</p>
            </div>
            <div class="text-center">
                <div class="text-4xl font-bold text-indigo-600">50+</div>
                <p class="text-slate-600 dark:text-slate-400">Systems Built</p>
            </div>
            <div class="text-center">
                <div class="text-4xl font-bold text-indigo-600">100M+</div>
                <p class="text-slate-600 dark:text-slate-400">Daily Requests</p>
            </div>
        </div>

        <section class="mb-12">
            <h2 class="text-3xl font-bold mb-6">Professional Background</h2>
            <div class="space-y-6">
                <div class="border-l-4 border-indigo-600 pl-6 py-2">
                    <h3 class="text-xl font-bold">Senior ML Infrastructure Engineer</h3>
                    <p class="text-slate-600 dark:text-slate-400">2023 - Present</p>
                    <p class="mt-2">Leading ML infrastructure initiatives, optimizing training pipelines, and scaling inference systems.</p>
                </div>
                <div class="border-l-4 border-indigo-600 pl-6 py-2">
                    <h3 class="text-xl font-bold">Platform Engineer</h3>
                    <p class="text-slate-600 dark:text-slate-400">2020 - 2023</p>
                    <p class="mt-2">Built internal developer platforms, CI/CD systems, and deployment automation.</p>
                </div>
                <div class="border-l-4 border-indigo-600 pl-6 py-2">
                    <h3 class="text-xl font-bold">DevOps Engineer</h3>
                    <p class="text-slate-600 dark:text-slate-400">2018 - 2020</p>
                    <p class="mt-2">Infrastructure automation, Kubernetes management, and cloud architecture.</p>
                </div>
            </div>
        </section>

        <section>
            <h2 class="text-3xl font-bold mb-6">Technical Skills</h2>
            <div class="grid md:grid-cols-2 gap-6">
                <div>
                    <h3 class="font-bold mb-3">Backend & Languages</h3>
                    <ul class="space-y-2 text-slate-600 dark:text-slate-400">
                        <li>Go, Python, Java</li>
                        <li>gRPC, Protocol Buffers</li>
                        <li>Microservices Architecture</li>
                    </ul>
                </div>
                <div>
                    <h3 class="font-bold mb-3">Infrastructure & Cloud</h3>
                    <ul class="space-y-2 text-slate-600 dark:text-slate-400">
                        <li>Kubernetes, Docker</li>
                        <li>AWS, GCP</li>
                        <li>CI/CD, GitHub Actions</li>
                    </ul>
                </div>
            </div>
        </section>
    </div>
</MainLayout>
