---
import MainLayout from '../layouts/MainLayout.astro';
import projects from '../data/projects.json';
---

<MainLayout title="Projects - Technical Showcase">
    <div class="py-6 max-w-4xl mx-auto">
        <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight mb-4">
            Technical <span class="bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 bg-clip-text text-transparent">Showcase</span>
        </h1>
        <p class="text-slate-500 dark:text-slate-400 mb-12 text-lg">A detailed view of production-grade platforms, system designs, and cloud-native solutions I have architected and built.</p>

        <!-- Projects Grid -->
        <div class="space-y-12">
            {projects.map(project => (
                <div class="p-8 bg-white dark:bg-slate-900/40 border border-slate-200/50 dark:border-slate-800/50 rounded-3xl shadow-sm hover:shadow-md transition-shadow duration-200">
                    <div class="flex flex-col md:flex-row md:justify-between md:items-start mb-6 gap-4">
                        <div>
                            <span class="text-xs font-semibold uppercase tracking-wider text-indigo-500 bg-indigo-50 dark:bg-indigo-950/50 px-3 py-1 rounded-full border border-indigo-100 dark:border-indigo-900/50 inline-block mb-3">
                                {project.tagline}
                            </span>
                            <h2 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-100">{project.name}</h2>
                        </div>
                    </div>

                    {project.image && (
                        <div class="mb-6 rounded-2xl overflow-hidden border border-slate-200/50 dark:border-slate-800/50">
                            <img src={project.image} alt={project.name} class="w-full max-h-56 object-cover" loading="lazy" />
                        </div>
                    )}

                    <p class="text-slate-700 dark:text-slate-300 leading-relaxed mb-6">{project.description}</p>

                    <!-- Key Features Accordion/List -->
                    <div class="mb-8">
                        <h3 class="font-bold text-sm uppercase tracking-wider text-slate-400 mb-4">Core Components & Features</h3>
                        <div class="grid gap-4 sm:grid-cols-2">
                            {project.features.map(feature => (
                                <div class="p-5 bg-slate-50 dark:bg-slate-950/50 border border-slate-200/50 dark:border-slate-800/50 rounded-2xl">
                                    <h4 class="font-bold text-slate-900 dark:text-slate-100 mb-1 flex items-center gap-2">
                                        <span class="text-indigo-500 text-xs">◆</span>
                                        {feature.title}
                                    </h4>
                                    <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed">{feature.detail}</p>
                                </div>
                            ))}
                        </div>
                    </div>

                    <!-- Tech Stack Tags -->
                    <div>
                        <h3 class="font-bold text-sm uppercase tracking-wider text-slate-400 mb-3">Technologies Used</h3>
                        <div class="flex flex-wrap gap-2">
                            {project.technologies.map(tech => (
                                <span class="bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 text-xs px-3 py-1.5 rounded-xl font-medium border border-slate-200/30 dark:border-slate-700/30">
                                    {tech}
                                </span>
                            ))}
                        </div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</MainLayout>
