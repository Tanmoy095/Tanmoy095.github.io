---
import MainLayout from '../layouts/MainLayout.astro';
import { site, social } from '../config';
---

<MainLayout title="Home - Aunmoy Dey Tanmoy">
    <section class="min-h-screen flex flex-col justify-center py-20">
        <div class="mb-12">
            <h1 class="text-6xl font-bold gradient-text mb-4">Aunmoy Dey Tanmoy</h1>
            <p class="text-2xl text-slate-600 dark:text-slate-300 mb-6">Senior AI Infrastructure Engineer</p>
            <p class="text-lg text-slate-600 dark:text-slate-300 max-w-2xl mb-8">
                Building scalable systems, optimizing ML infrastructure, and sharing knowledge about backend engineering, Go, and system design.
            </p>
            <div class="flex gap-4 mb-12">
                <a href="/blog" class="px-6 py-3 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 font-medium">Read Blog</a>
                <a href="/projects" class="px-6 py-3 border border-indigo-600 text-indigo-600 rounded-lg hover:bg-indigo-50 dark:hover:bg-slate-900 font-medium">View Projects</a>
            </div>
        </div>

        <section class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-16">
            <a href=`mailto:${site.email}` class="p-6 border border-slate-200 dark:border-slate-800 rounded-lg hover:border-indigo-600 transition">
                <div class="text-sm text-slate-600 dark:text-slate-400 mb-2">Email</div>
                <div class="font-mono text-sm break-all">{site.email}</div>
            </a>
            <a href=`tel:${site.phone}` class="p-6 border border-slate-200 dark:border-slate-800 rounded-lg hover:border-indigo-600 transition">
                <div class="text-sm text-slate-600 dark:text-slate-400 mb-2">Phone</div>
                <div class="font-mono text-sm">{site.phone}</div>
            </a>
            <a href={social.linkedin} target="_blank" class="p-6 border border-slate-200 dark:border-slate-800 rounded-lg hover:border-indigo-600 transition">
                <div class="text-sm text-slate-600 dark:text-slate-400 mb-2">LinkedIn</div>
                <div class="font-medium text-sm">Profile</div>
            </a>
            <a href={social.github} target="_blank" class="p-6 border border-slate-200 dark:border-slate-800 rounded-lg hover:border-indigo-600 transition">
                <div class="text-sm text-slate-600 dark:text-slate-400 mb-2">GitHub</div>
                <div class="font-medium text-sm">Repository</div>
            </a>
        </section>
    </section>
</MainLayout>
