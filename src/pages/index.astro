---
import MainLayout from '../layouts/MainLayout.astro';
import profile from '../data/profile.json';
---

<MainLayout title="Home - Technical Portfolio">
    <section class="py-16 md:py-24 flex flex-col justify-center">
        <!-- Hero Section -->
        <div class="max-w-3xl mb-16">
            <span class="text-indigo-600 dark:text-indigo-400 font-semibold tracking-wider text-sm uppercase mb-3 block">Welcome to my space</span>
            <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-6 leading-tight">
                Hi, I'm <span class="bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 bg-clip-text text-transparent">{profile.name}</span>
            </h1>
            <p class="text-2xl font-bold text-slate-700 dark:text-slate-200 mb-6 leading-relaxed">
                {profile.title}
            </p>
            <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed mb-8 max-w-2xl">
                {profile.summary}
            </p>
            <div class="flex flex-wrap gap-4">
                <a href="/blog" class="px-6 py-3.5 bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 text-white rounded-xl font-semibold hover:shadow-lg hover:shadow-indigo-500/20 active:scale-95 transition duration-200 text-sm uppercase tracking-wider">
                    Read Blog
                </a>
                <a href="/projects" class="px-6 py-3.5 border border-slate-300 dark:border-slate-800 text-slate-700 dark:text-slate-300 rounded-xl font-semibold hover:bg-slate-100 dark:hover:bg-slate-900 active:scale-95 transition duration-200 text-sm uppercase tracking-wider">
                    View Projects
                </a>
            </div>
        </div>

        <!-- Metrics Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-20">
            <div class="p-8 bg-white dark:bg-slate-900/50 border border-slate-200/50 dark:border-slate-800/50 rounded-2xl shadow-sm">
                <div class="text-4xl font-extrabold text-indigo-600 dark:text-indigo-400 mb-2">6+</div>
                <div class="text-sm font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">Years Experience</div>
            </div>
            <div class="p-8 bg-white dark:bg-slate-900/50 border border-slate-200/50 dark:border-slate-800/50 rounded-2xl shadow-sm">
                <div class="text-4xl font-extrabold text-purple-600 dark:text-purple-400 mb-2">50+</div>
                <div class="text-sm font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">Production Systems</div>
            </div>
            <div class="p-8 bg-white dark:bg-slate-900/50 border border-slate-200/50 dark:border-slate-800/50 rounded-2xl shadow-sm">
                <div class="text-4xl font-extrabold text-pink-600 dark:text-pink-400 mb-2">100M+</div>
                <div class="text-sm font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">Daily Requests Served</div>
            </div>
        </div>

        <!-- Quick Skills Section -->
        <div class="mb-20">
            <h2 class="text-3xl font-extrabold mb-8 tracking-tight">Core Competencies</h2>
            <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-4">
                {profile.skills.slice(0, 4).map(skill => (
                    <div class="p-6 bg-white dark:bg-slate-900/30 border border-slate-200/50 dark:border-slate-800/50 rounded-xl">
                        <h3 class="font-bold text-lg mb-3 text-slate-800 dark:text-slate-200">{skill.category}</h3>
                        <div class="flex flex-wrap gap-1.5">
                            {skill.items.slice(0, 4).map(item => (
                                <span class="bg-slate-100 dark:bg-slate-800/50 text-slate-600 dark:text-slate-400 text-xs px-2.5 py-1 rounded-md font-medium">
                                    {item}
                                </span>
                            ))}
                        </div>
                    </div>
                ))}
            </div>
        </div>

        <!-- Contact Section -->
        <div id="contact" class="pt-8 border-t border-slate-200 dark:border-slate-800">
            <h2 class="text-3xl font-extrabold mb-3 tracking-tight text-center md:text-left">Let's Connect</h2>
            <p class="text-slate-500 dark:text-slate-400 mb-8 max-w-lg text-center md:text-left">Feel free to reach out for collaboration, project design, or consulting opportunities.</p>
            
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <a href={`mailto:${profile.email}`} class="p-6 bg-white dark:bg-slate-900/50 border border-slate-200/50 dark:border-slate-800/50 rounded-2xl hover:border-indigo-500 dark:hover:border-indigo-500 hover:shadow-md transition-all duration-200 group text-center md:text-left">
                    <div class="text-2xl mb-3 group-hover:scale-110 transition-transform duration-200">✉️</div>
                    <div class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1">Email</div>
                    <div class="font-mono text-xs text-slate-800 dark:text-slate-200 break-all">{profile.email}</div>
                </a>
                <a href={`tel:${profile.phone}`} class="p-6 bg-white dark:bg-slate-900/50 border border-slate-200/50 dark:border-slate-800/50 rounded-2xl hover:border-purple-500 dark:hover:border-purple-500 hover:shadow-md transition-all duration-200 group text-center md:text-left">
                    <div class="text-2xl mb-3 group-hover:scale-110 transition-transform duration-200">📱</div>
                    <div class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1">Phone</div>
                    <div class="font-mono text-xs text-slate-800 dark:text-slate-200">{profile.phone}</div>
                </a>
                <a href={profile.linkedin} target="_blank" class="p-6 bg-white dark:bg-slate-900/50 border border-slate-200/50 dark:border-slate-800/50 rounded-2xl hover:border-pink-500 dark:hover:border-pink-500 hover:shadow-md transition-all duration-200 group text-center md:text-left">
                    <div class="text-2xl mb-3 group-hover:scale-110 transition-transform duration-200">💼</div>
                    <div class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1">LinkedIn</div>
                    <div class="text-xs font-semibold text-slate-800 dark:text-slate-200">View Profile</div>
                </a>
                <a href={profile.github} target="_blank" class="p-6 bg-white dark:bg-slate-900/50 border border-slate-200/50 dark:border-slate-800/50 rounded-2xl hover:border-slate-600 dark:hover:border-slate-400 hover:shadow-md transition-all duration-200 group text-center md:text-left">
                    <div class="text-2xl mb-3 group-hover:scale-110 transition-transform duration-200">💻</div>
                    <div class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1">GitHub</div>
                    <div class="text-xs font-semibold text-slate-800 dark:text-slate-200">View Projects</div>
                </a>
            </div>
        </div>
    </section>
</MainLayout>
