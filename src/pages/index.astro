---
import MainLayout from '../layouts/MainLayout.astro';

const recentPosts = [
  {
    title: 'Building Scalable AI Infrastructure',
    slug: 'scalable-ai-infrastructure',
    date: new Date('2026-06-10'),
    excerpt: 'Best practices for designing distributed systems for AI workloads'
  },
  {
    title: 'Kubernetes at Scale: Lessons Learned',
    slug: 'kubernetes-scale',
    date: new Date('2026-06-08'),
    excerpt: 'Real-world insights from managing large-scale Kubernetes clusters'
  },
  {
    title: 'GPU Resource Management',
    slug: 'gpu-resource-management',
    date: new Date('2026-06-05'),
    excerpt: 'Optimizing GPU allocation and scheduling in cloud environments'
  },
];

const skills = [
  { category: 'AI Infrastructure', items: ['MLOps', 'CUDA', 'Distributed Training', 'Model Serving'] },
  { category: 'Cloud Platforms', items: ['AWS', 'GCP', 'Azure', 'Kubernetes'] },
  { category: 'Data Systems', items: ['Elasticsearch', 'Kafka', 'PostgreSQL', 'Ray'] },
  { category: 'Languages', items: ['Python', 'Go', 'Rust', 'TypeScript'] },
];
---

<MainLayout title="Senior AI Infrastructure Engineer - Portfolio">
  <!-- Hero Section -->
  <section class="min-h-screen flex items-center justify-center bg-gradient-to-br from-primary/10 via-transparent to-secondary/10">
    <div class="section-container w-full">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="animate-fade-in">
          <h1 class="text-5xl md:text-6xl font-bold mb-6 leading-tight">
            <span class="gradient-text">Senior AI Infrastructure</span>
            <br />
            Engineer
          </h1>
          <p class="text-xl text-slate-600 dark:text-slate-400 mb-8 leading-relaxed">
            Building scalable ML systems, optimizing distributed computing, and crafting elegant solutions to complex infrastructure challenges.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/projects" class="btn-primary">View My Work</a>
            <a href="/blog" class="btn-secondary">Read My Blog</a>
          </div>
          <div class="flex gap-4 mt-8">
            <a href="#" class="p-3 bg-slate-200 dark:bg-slate-800 rounded-lg hover:bg-primary/10 transition">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v 3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            </a>
            <a href="#" class="p-3 bg-slate-200 dark:bg-slate-800 rounded-lg hover:bg-primary/10 transition">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
            </a>
            <a href="#" class="p-3 bg-slate-200 dark:bg-slate-800 rounded-lg hover:bg-primary/10 transition">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2s9 5 20 5a9.5 9.5 0 00-9-5.5c4.75 2.25 7-7 7-7a10.6 10.6 0 01-3 1m0 0v-1.5a4.5 4.5 0 00-8-0"/></svg>
            </a>
          </div>
        </div>
        <div class="animate-slide-up">
          <div class="relative">
            <div class="absolute inset-0 bg-gradient-to-br from-primary to-secondary rounded-2xl blur-3xl opacity-20"></div>
            <div class="relative bg-slate-100 dark:bg-slate-800 rounded-2xl p-8 backdrop-blur">
              <div class="aspect-square bg-gradient-to-br from-primary/20 to-secondary/20 rounded-xl flex items-center justify-center">
                <span class="text-6xl font-bold gradient-text">YN</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Skills Section -->
  <section class="section-container">
    <h2 class="text-4xl font-bold mb-12 text-center">Core Skills & Expertise</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {skills.map(skill => (
        <div class="card animate-fade-in">
          <h3 class="text-lg font-bold mb-4 text-primary">{skill.category}</h3>
          <ul class="space-y-2">
            {skill.items.map(item => (
              <li class="flex items-center gap-2">
                <span class="w-2 h-2 bg-primary rounded-full"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- Featured Projects Preview -->
  <section class="section-container bg-gradient-to-br from-slate-50 to-slate-100 dark:from-slate-800 dark:to-slate-900 rounded-2xl">
    <h2 class="text-4xl font-bold mb-12">Featured Projects</h2>
    <div class="grid md:grid-cols-3 gap-6 mb-8">
      {[1, 2, 3].map(i => (
        <div class="card group cursor-pointer">
          <div class="h-48 bg-gradient-to-br from-primary/20 to-secondary/20 rounded-lg mb-4 group-hover:from-primary/30 group-hover:to-secondary/30 transition flex items-center justify-center">
            <span class="text-4xl">📦</span>
          </div>
          <h3 class="text-xl font-bold mb-2">Project {i}</h3>
          <p class="text-slate-600 dark:text-slate-400 mb-4">Cutting-edge infrastructure solution leveraging modern technologies</p>
          <div class="flex flex-wrap gap-2">
            <span class="text-xs bg-primary/10 text-primary px-2 py-1 rounded">Python</span>
            <span class="text-xs bg-secondary/10 text-secondary px-2 py-1 rounded">K8s</span>
          </div>
        </div>
      ))}
    </div>
    <div class="text-center">
      <a href="/projects" class="btn-primary">View All Projects</a>
    </div>
  </section>

  <!-- Recent Blog Posts -->
  <section class="section-container">
    <h2 class="text-4xl font-bold mb-12">Latest Blog Posts</h2>
    <div class="space-y-6">
      {recentPosts.map(post => (
        <article class="card group cursor-pointer border-l-4 border-primary hover:border-secondary transition">
          <div class="flex flex-col md:flex-row justify-between md:items-start gap-4">
            <div class="flex-1">
              <time class="text-sm text-slate-500 dark:text-slate-400">
                {post.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
              <h3 class="text-2xl font-bold mb-2 group-hover:text-primary transition">
                <a href={`/blog/${post.slug}`}>{post.title}</a>
              </h3>
              <p class="text-slate-600 dark:text-slate-400">{post.excerpt}</p>
            </div>
            <span class="text-primary text-2xl group-hover:translate-x-2 transition">→</span>
          </div>
        </article>
      ))}
    </div>
    <div class="text-center mt-12">
      <a href="/blog" class="btn-secondary">Read More Articles</a>
    </div>
  </section>

  <!-- CTA Section -->
  <section id="contact" class="section-container bg-gradient-to-r from-primary to-secondary text-white rounded-2xl">
    <div class="text-center">
      <h2 class="text-4xl font-bold mb-6">Ready to Collaborate?</h2>
      <p class="text-xl mb-12 opacity-90">Let's build something amazing together. Whether it's a project discussion or just a quick chat about infrastructure challenges.</p>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <div class="bg-white/10 backdrop-blur rounded-lg p-6 hover:bg-white/20 transition">
          <div class="text-3xl mb-2">📧</div>
          <h3 class="font-semibold mb-2">Email</h3>
          <a href="mailto:adtanmoy95@gmail.com" class="hover:underline break-all">adtanmoy95@gmail.com</a>
        </div>
        <div class="bg-white/10 backdrop-blur rounded-lg p-6 hover:bg-white/20 transition">
          <div class="text-3xl mb-2">📱</div>
          <h3 class="font-semibold mb-2">Phone</h3>
          <a href="tel:+8801850371329" class="hover:underline">+880 1850 371329</a>
        </div>
        <div class="bg-white/10 backdrop-blur rounded-lg p-6 hover:bg-white/20 transition">
          <div class="text-3xl mb-2">💼</div>
          <h3 class="font-semibold mb-2">LinkedIn</h3>
          <a href="https://linkedin.com/in/aunmoy-dey-tanmoy095" target="_blank" class="hover:underline">View Profile</a>
        </div>
        <div class="bg-white/10 backdrop-blur rounded-lg p-6 hover:bg-white/20 transition">
          <div class="text-3xl mb-2">🐙</div>
          <h3 class="font-semibold mb-2">GitHub</h3>
          <a href="https://github.com/Tanmoy095" target="_blank" class="hover:underline">View Repos</a>
        </div>
      </div>
      <a href="mailto:adtanmoy95@gmail.com" class="inline-block px-8 py-4 bg-white text-primary hover:bg-slate-100 rounded-lg font-semibold transition">
        Send Me an Email
      </a>
    </div>
  </section>
</MainLayout>
