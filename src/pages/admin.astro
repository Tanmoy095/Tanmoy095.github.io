        const oldPath = document.getElementById('blog-old-path').value;
        const newPath = `src/content/blog/${slug}.md`;
        
        try {
            const data = {
                title: document.getElementById('blog-title').value.trim(),
                description: document.getElementById('blog-desc').value.trim(),
                pubDate: document.getElementById('blog-date').value,
                slug: slug,
                tags: document.getElementById('blog-tags').value.split(',').map(s => s.trim()).filter(Boolean)
