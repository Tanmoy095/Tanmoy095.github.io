---
import MainLayout from '../layouts/MainLayout.astro';

const adminEmail = import.meta.env.PUBLIC_ADMIN_EMAIL || 'adtanmoy95@gmail.com';
const passwordHash = import.meta.env.PUBLIC_ADMIN_PASSWORD_HASH || '240be518fabd2724ddb6f04eeb1da5967448d7e831c08c8fa822809f74c720a9'; // default: admin123
---

<MainLayout title="Admin Dashboard - CMS Panel">
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js" is:inline></script>
    <script is:inline define:vars={{ adminEmail, passwordHash }}>
        window.__ADMIN_CONFIG__ = { email: adminEmail, passwordHash };
    </script>
    <script src="/admin-cms.js" defer></script>

    <div id="cms-toast" class="hidden fixed bottom-6 right-6 z-[100] opacity-0 transition-opacity"></div>

    <!-- LOGIN SCREEN -->
    <div id="login-screen" class="max-w-md mx-auto py-16">
        <div class="text-center mb-10">
            <div class="text-5xl mb-4">🔐</div>
            <h1 class="text-3xl font-extrabold tracking-tight mb-2">Admin Access</h1>
            <p id="login-hint" class="text-slate-500 text-sm">Enter your credentials to manage the portfolio.</p>
        </div>
        <form id="login-form" class="bg-white dark:bg-slate-900/40 border border-slate-200/50 dark:border-slate-800/50 p-8 rounded-3xl shadow-sm space-y-5">
            <div>
                <label class="label-heading">Admin Email</label>
                <input type="email" id="login-email" required class="form-input" placeholder="your@email.com" />
            </div>
            <div>
                <label class="label-heading">Password</label>
                <input type="password" id="login-password" required class="form-input" placeholder="••••••••" />
            </div>
            <button type="submit" id="login-submit" class="btn-primary w-full py-3 text-sm uppercase font-semibold tracking-wide">Unlock Dashboard</button>
        </form>
    </div>

    <!-- DASHBOARD -->
    <div id="dashboard-screen" class="hidden py-6">
        <div class="mb-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
            <div>
                <h1 class="text-3xl font-extrabold tracking-tight">CMS <span class="bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 bg-clip-text text-transparent">Dashboard</span></h1>
                <p id="mode-label" class="text-xs text-slate-500 mt-1"></p>
            </div>
            <div class="flex items-center gap-3">
                <div id="status-badge" class="px-4 py-2 rounded-xl text-xs font-semibold uppercase"></div>
                <button id="btn-logout" type="button" class="btn-secondary py-2 px-4 text-xs">Logout</button>
            </div>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
            <div class="p-4 bg-indigo-50/50 dark:bg-indigo-950/20 border border-indigo-100/30 rounded-2xl">
                <div id="stat-profile" class="text-lg font-bold text-indigo-600">—</div>
                <p class="text-[10px] uppercase font-semibold text-slate-500">Profile</p>
            </div>
            <div class="p-4 bg-purple-50/50 dark:bg-purple-950/20 border border-purple-100/30 rounded-2xl">
                <div id="stat-projects" class="text-lg font-bold text-purple-600">—</div>
                <p class="text-[10px] uppercase font-semibold text-slate-500">Projects</p>
            </div>
            <div class="p-4 bg-pink-50/50 dark:bg-pink-950/20 border border-pink-100/30 rounded-2xl">
                <div id="stat-blogs" class="text-lg font-bold text-pink-600">—</div>
                <p class="text-[10px] uppercase font-semibold text-slate-500">Blogs</p>
            </div>
            <div class="p-4 bg-blue-50/50 dark:bg-blue-950/20 border border-blue-100/30 rounded-2xl">
                <div id="stat-learnings" class="text-lg font-bold text-blue-600">—</div>
                <p class="text-[10px] uppercase font-semibold text-slate-500">Learnings</p>
            </div>
        </div>

        <div class="mb-6">
            <button id="btn-reload-all" type="button" class="btn-secondary text-xs py-2 px-4">↻ Reload All Content from Git</button>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
            <div class="lg:col-span-3 flex flex-row lg:flex-col gap-2 overflow-x-auto lg:overflow-x-visible pb-4 lg:pb-0">
                <button class="nav-tab active" data-target="tab-profile">👤 About & Skills</button>
                <button class="nav-tab" data-target="tab-projects">📂 Projects</button>
                <button class="nav-tab" data-target="tab-blogs">✍️ Blogs</button>
                <button class="nav-tab" data-target="tab-learnings">📖 Learnings & ADRs</button>
                <button class="nav-tab" data-target="tab-settings" id="pat-settings">⚙️ Settings</button>
            </div>

            <div class="lg:col-span-9 bg-white dark:bg-slate-900/30 border border-slate-200/50 dark:border-slate-800/50 p-6 sm:p-8 rounded-3xl shadow-sm min-h-[500px]">

                <!-- PROFILE -->
                <div id="tab-profile" class="tab-panel space-y-6">
                    <h2 class="text-2xl font-bold border-b border-slate-100 dark:border-slate-800 pb-3">About Me & Homepage</h2>
                    <p id="profile-prompt" class="text-slate-400 text-sm hidden">Loading...</p>
                    <form id="profile-form" class="space-y-6">
                        <div class="grid sm:grid-cols-2 gap-4">
                            <div><label class="label-heading">Full Name</label><input type="text" id="prof-name" required class="form-input" /></div>
                            <div><label class="label-heading">Professional Title</label><input type="text" id="prof-title" required class="form-input" /></div>
                        </div>
                        <div class="grid sm:grid-cols-3 gap-4">
                            <div><label class="label-heading">Email</label><input type="email" id="prof-email" required class="form-input" /></div>
                            <div><label class="label-heading">Phone</label><input type="text" id="prof-phone" class="form-input" /></div>
                            <div><label class="label-heading">Location</label><input type="text" id="prof-location" class="form-input" /></div>
                        </div>
                        <div class="grid sm:grid-cols-3 gap-4">
                            <div><label class="label-heading">GitHub</label><input type="url" id="prof-github" class="form-input" /></div>
                            <div><label class="label-heading">LinkedIn</label><input type="url" id="prof-linkedin" class="form-input" /></div>
                            <div><label class="label-heading">Twitter</label><input type="url" id="prof-twitter" class="form-input" /></div>
                        </div>
                        <div class="grid sm:grid-cols-2 gap-4 items-end">
                            <div>
                                <label class="label-heading">CV / Resume PDF Upload</label>
                                <input type="file" id="prof-cv-file" accept="application/pdf" class="form-input text-xs" />
                            </div>
                            <div>
                                <label class="label-heading">CV URL Path</label>
                                <input type="text" id="prof-cv-url" placeholder="/cv.pdf" class="form-input" />
                            </div>
                        </div>
                        <div><label class="label-heading">Homepage Summary</label><textarea id="prof-summary" rows="3" class="form-input"></textarea></div>
                        <div><label class="label-heading">About Page — Detailed Summary</label><textarea id="prof-detailedSummary" rows="4" class="form-input"></textarea></div>
                        <div><label class="label-heading">Career Objective</label><textarea id="prof-objective" rows="3" class="form-input"></textarea></div>
                        <div><label class="label-heading">Recruiter Summary</label><textarea id="prof-recruiter" rows="3" class="form-input"></textarea></div>

                        <div>
                            <div class="flex justify-between items-center mb-3">
                                <label class="label-heading mb-0">Target Roles</label>
                                <button type="button" id="btn-add-role" class="text-xs text-indigo-600 font-semibold">+ Add Role</button>
                            </div>
                            <div id="roles-editor"></div>
                        </div>

                        <div>
                            <div class="flex justify-between items-center mb-3">
                                <label class="label-heading mb-0">Skills & Categories</label>
                                <button type="button" id="btn-add-skill-cat" class="text-xs text-indigo-600 font-semibold">+ Add Category</button>
                            </div>
                            <div id="skills-editor" class="space-y-4"></div>
                        </div>

                        <div>
                            <div class="flex justify-between items-center mb-3">
                                <label class="label-heading mb-0">Experience Highlights</label>
                                <button type="button" id="btn-add-highlight" class="text-xs text-indigo-600 font-semibold">+ Add Highlight</button>
                            </div>
                            <div id="highlights-editor" class="space-y-4"></div>
                        </div>

                        <div>
                            <div class="flex justify-between items-center mb-3">
                                <label class="label-heading mb-0">Work History</label>
                                <button type="button" id="btn-add-history" class="text-xs text-indigo-600 font-semibold">+ Add Job</button>
                            </div>
                            <div id="history-editor" class="space-y-4"></div>
                        </div>

                        <button type="submit" class="btn-primary w-full py-3 text-sm uppercase font-semibold">Publish About & Profile Live</button>
                    </form>
                </div>

                <!-- PROJECTS -->
                <div id="tab-projects" class="tab-panel hidden space-y-6">
                    <div class="flex justify-between items-center border-b pb-3">
                        <h2 class="text-2xl font-bold">Projects</h2>
                        <button id="btn-add-project" type="button" class="btn-primary py-1.5 px-3 text-xs hidden">+ New Project</button>
                    </div>
                    <div id="projects-list-container" class="space-y-3"></div>
                    <p id="projects-prompt" class="text-slate-400 text-sm text-center py-6">Loading projects...</p>
                    <form id="project-form" class="hidden space-y-4 p-6 bg-slate-50 dark:bg-slate-900/50 rounded-2xl border">
                        <h3 id="project-form-title" class="font-bold text-lg">New Project</h3>
                        <input type="hidden" id="proj-index" />
                        <div class="grid sm:grid-cols-2 gap-4">
                            <div><label class="label-heading">Slug / ID</label><input type="text" id="proj-id" required class="form-input" /></div>
                            <div><label class="label-heading">Name</label><input type="text" id="proj-name" required class="form-input" /></div>
                        </div>
                        <div><label class="label-heading">Tagline</label><input type="text" id="proj-tagline" required class="form-input" /></div>
                        <div><label class="label-heading">Description</label><textarea id="proj-desc" rows="3" required class="form-input"></textarea></div>
                        <div><label class="label-heading">Cover Image URL</label><input type="text" id="proj-image" placeholder="/blog-assets/project-cover.jpg" class="form-input" /></div>
                        <div><label class="label-heading">Technologies (comma-separated)</label><input type="text" id="proj-tech" class="form-input" /></div>
                        <div>
                            <div class="flex justify-between items-center mb-3">
                                <label class="label-heading mb-0">Project Key Features</label>
                                <button type="button" id="btn-add-proj-feature" class="text-xs text-indigo-600 font-semibold">+ Add Feature</button>
                            </div>
                            <div id="proj-features-editor" class="space-y-3"></div>
                        </div>
                        <div class="flex gap-2">
                            <button type="submit" class="btn-primary py-2 px-4 text-xs">Publish Project Live</button>
                            <button id="btn-cancel-project" type="button" class="btn-secondary py-2 px-4 text-xs">Cancel</button>
                        </div>
                    </form>
                    <button id="btn-publish-projects" type="button" class="btn-primary w-full py-3 text-sm uppercase font-semibold hidden">Publish Projects Live</button>
                </div>

                <!-- BLOGS -->
                <div id="tab-blogs" class="tab-panel hidden space-y-6">
                    <div class="flex justify-between items-center border-b pb-3">
                        <h2 class="text-2xl font-bold">Technical Blogs</h2>
                        <button id="btn-create-blog" type="button" class="btn-primary py-1.5 px-3 text-xs hidden">+ Write Blog</button>
                    </div>
                    <div id="blogs-list-container" class="space-y-3"></div>
                    <p id="blogs-prompt" class="text-slate-400 text-sm text-center py-6">Loading blogs...</p>
                    <form id="blog-form" class="hidden space-y-4 p-6 bg-slate-50 dark:bg-slate-900/50 rounded-2xl border">
                        <h3 class="font-bold text-lg">Blog Editor</h3>
                        <input type="hidden" id="blog-sha" /><input type="hidden" id="blog-old-path" />
                        <div class="grid sm:grid-cols-2 gap-4">
                            <div><label class="label-heading">Slug</label><input type="text" id="blog-slug" required class="form-input" /></div>
                            <div><label class="label-heading">Publish Date</label><input type="date" id="blog-date" required class="form-input" /></div>
                        </div>
                        <div><label class="label-heading">Title</label><input type="text" id="blog-title" required class="form-input" /></div>
                        <div><label class="label-heading">Description</label><input type="text" id="blog-desc" required class="form-input" /></div>
                        <div><label class="label-heading">Tags (comma-separated)</label><input type="text" id="blog-tags" class="form-input" /></div>
                        <div class="grid sm:grid-cols-2 gap-4 items-end">
                            <div>
                                <label class="label-heading">Cover Image Upload</label>
                                <input type="file" id="blog-image-file" accept="image/*" class="form-input text-xs" />
                            </div>
                            <div>
                                <label class="label-heading">Or Image URL</label>
                                <input type="text" id="blog-image" placeholder="/blog-assets/my-post.jpg" class="form-input" />
                            </div>
                        </div>
                        <img id="blog-image-preview" class="hidden max-h-40 rounded-xl border border-slate-200" alt="Preview" />
                        <div>
                            <div class="flex border-b mb-3">
                                <button type="button" id="blog-write-tab" class="px-4 py-2 text-xs font-semibold bg-slate-100 dark:bg-slate-800 rounded-t-xl">Write</button>
                                <button type="button" id="blog-preview-tab" class="px-4 py-2 text-xs font-semibold text-slate-500">Preview</button>
                            </div>
                            <div id="blog-write-container"><textarea id="blog-content" rows="14" required class="form-input font-mono text-xs"></textarea></div>
                            <div id="blog-preview-container" class="hidden p-4 bg-white dark:bg-slate-950 border rounded-xl min-h-[200px] markdown-body"></div>
                        </div>
                        <div class="flex gap-2 justify-between">
                            <div class="flex gap-2">
                                <button type="submit" class="btn-primary py-2 px-4 text-xs">Publish Blog Live</button>
                                <button id="btn-cancel-blog" type="button" class="btn-secondary py-2 px-4 text-xs">Cancel</button>
                            </div>
                            <button id="btn-delete-blog" type="button" class="hidden px-4 py-2 text-xs bg-rose-600 text-white rounded-xl">Delete</button>
                        </div>
                    </form>
                </div>

                <!-- LEARNINGS -->
                <div id="tab-learnings" class="tab-panel hidden space-y-6">
                    <div class="flex justify-between items-center border-b pb-3">
                        <h2 class="text-2xl font-bold">Daily Learnings & ADRs</h2>
                        <button id="btn-create-learning" type="button" class="btn-primary py-1.5 px-3 text-xs hidden">+ New Entry</button>
                    </div>
                    <div id="learnings-list-container" class="space-y-3"></div>
                    <p id="learnings-prompt" class="text-slate-400 text-sm text-center py-6">Loading entries...</p>
                    <form id="learning-form" class="hidden space-y-4 p-6 bg-slate-50 dark:bg-slate-900/50 rounded-2xl border">
                        <h3 class="font-bold text-lg">Learning / ADR Editor</h3>
                        <input type="hidden" id="learn-sha" /><input type="hidden" id="learn-old-path" />
                        <div class="grid sm:grid-cols-2 gap-4">
                            <div><label class="label-heading">Slug</label><input type="text" id="learn-slug" required class="form-input" placeholder="entry-05-topic or adr-003-decision" /></div>
                            <div><label class="label-heading">Date</label><input type="date" id="learn-date" required class="form-input" /></div>
                        </div>
                        <div><label class="label-heading">Title</label><input type="text" id="learn-title" required class="form-input" /></div>
                        <div class="grid sm:grid-cols-3 gap-4 items-center">
                            <div><label class="label-heading">Category</label><input type="text" id="learn-category" required class="form-input" /></div>
                            <div class="flex items-center mt-6 gap-2">
                                <input type="checkbox" id="learn-isADR" class="rounded" />
                                <label for="learn-isADR" class="text-sm font-semibold">Is ADR?</label>
                            </div>
                            <div>
                                <label class="label-heading">ADR Status</label>
                                <select id="learn-adrStatus" disabled class="form-input">
                                    <option value="">—</option>
                                    <option value="Accepted">Accepted</option>
                                    <option value="Proposed">Proposed</option>
                                    <option value="Deprecated">Deprecated</option>
                                </select>
                            </div>
                        </div>
                        <div><label class="label-heading">Tags</label><input type="text" id="learn-tags" class="form-input" /></div>
                        <div>
                            <div class="flex border-b mb-3">
                                <button type="button" id="learn-write-tab" class="px-4 py-2 text-xs font-semibold bg-slate-100 dark:bg-slate-800 rounded-t-xl">Write</button>
                                <button type="button" id="learn-preview-tab" class="px-4 py-2 text-xs font-semibold text-slate-500">Preview</button>
                            </div>
                            <div id="learn-write-container"><textarea id="learn-content" rows="10" required class="form-input font-mono text-xs"></textarea></div>
                            <div id="learn-preview-container" class="hidden p-4 bg-white dark:bg-slate-950 border rounded-xl min-h-[160px] markdown-body"></div>
                        </div>
                        <div class="flex gap-2 justify-between">
                            <div class="flex gap-2">
                                <button type="submit" class="btn-primary py-2 px-4 text-xs">Publish Entry Live</button>
                                <button id="btn-cancel-learning" type="button" class="btn-secondary py-2 px-4 text-xs">Cancel</button>
                            </div>
                            <button id="btn-delete-learning" type="button" class="hidden px-4 py-2 text-xs bg-rose-600 text-white rounded-xl">Delete</button>
                        </div>
                    </form>
                </div>

                <!-- SETTINGS -->
                <div id="tab-settings" class="tab-panel hidden space-y-6">
                    <h2 class="text-2xl font-bold border-b pb-3">GitHub PAT Settings</h2>
                    <p class="text-xs text-slate-500">Required on <strong>GitHub Pages</strong> only. On Vercel, the server manages the GitHub token automatically.</p>
                    <form id="config-form" class="space-y-4">
                        <div><label class="label-heading">GitHub Owner</label><input type="text" id="cfg-owner" class="form-input" /></div>
                        <div><label class="label-heading">Repository</label><input type="text" id="cfg-repo" class="form-input" /></div>
                        <div><label class="label-heading">Branch</label><input type="text" id="cfg-branch" class="form-input" /></div>
                        <div>
                            <label class="label-heading">Personal Access Token</label>
                            <input type="password" id="cfg-token" class="form-input" placeholder="ghp_..." />
                            <p class="text-[10px] text-slate-400 mt-1">
                                💡 Ensure your token has <strong>write permissions</strong>. For classic tokens, check the <code>repo</code> scope. For fine-grained tokens, grant <strong>Read and Write</strong> access to <strong>Repository Contents</strong>. Note: <em>Test Connection</em> only verifies read access.
                            </p>
                        </div>
                        <div class="flex gap-3">
                            <button type="submit" class="btn-primary flex-1 py-3 text-sm uppercase font-semibold">Save Settings</button>
                            <button type="button" id="btn-test-connection" class="btn-secondary py-3 px-5 text-sm font-semibold">Test Connection</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</MainLayout>

<style is:global>
    .form-input { width: 100%; background: rgb(248,250,252); border: 1px solid rgb(226,232,240); border-radius: 0.75rem; padding: 0.625rem 1rem; font-size: 0.875rem; transition: all 0.2s; }
    .dark .form-input { background: rgb(3,7,18); border-color: rgb(30,41,59); }
    .form-input:focus { outline: none; border-color: rgb(99,102,241); box-shadow: 0 0 0 1px rgb(99,102,241); }
    .label-heading { display: block; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: rgb(100,116,139); margin-bottom: 0.5rem; }
    .btn-primary { background: linear-gradient(135deg, #6366f1, #a855f7, #ec4899); color: white; border-radius: 0.75rem; padding: 0.5rem 1rem; font-weight: 600; }
    .btn-secondary { background: rgb(241,245,249); color: rgb(15,23,42); border: 1px solid rgb(226,232,240); border-radius: 0.75rem; padding: 0.5rem 1rem; font-weight: 600; }
    .dark .btn-secondary { background: rgb(15,23,42); color: rgb(248,250,252); border-color: rgb(30,41,59); }
    .nav-tab { padding: 0.75rem 1rem; text-align: left; border-radius: 0.75rem; font-size: 0.875rem; font-weight: 600; border: 1px solid rgb(226,232,240); white-space: nowrap; transition: all 0.2s; }
    .dark .nav-tab { border-color: rgb(30,41,59); }
    .nav-tab.active { background: linear-gradient(135deg, rgba(99,102,241,0.12), rgba(236,72,153,0.08)); color: rgb(99,102,241); border-color: rgba(99,102,241,0.4); }
</style>
