        learnWriteContainer.classList.add('hidden');
        learnPreviewContainer.classList.remove('hidden');
        
        const mdText = document.getElementById('learn-content').value;
        learnPreviewContainer.innerHTML = typeof marked !== 'undefined' ? marked.parse(mdText) : mdText;
    });

    // Toggle ADR status dropdown based on checkbox
    const adrCheckbox = document.getElementById('learn-isADR');
    const adrStatusDropdown = document.getElementById('learn-adrStatus');
    adrCheckbox.addEventListener('change', () => {
        adrStatusDropdown.disabled = !adrCheckbox.checked;
        if (!adrCheckbox.checked) adrStatusDropdown.value = '';
    });

    function buildLearningFrontmatter(data, body) {
        let yaml = '---\n';
        yaml += `title: "${data.title}"\n`;
        yaml += `date: "${data.date}"\n`;
        yaml += `category: "${data.category}"\n`;
        yaml += `tags: [${data.tags.map(t => `"${t}"`).join(', ')}]\n`;
        yaml += `isADR: ${data.isADR}\n`;
        if (data.isADR && data.adrStatus) {
            yaml += `adrStatus: "${data.adrStatus}"\n`;
        }
        yaml += '---\n\n';
        yaml += body;
        return yaml;
    }

    function renderLearningsList() {
        learnContainer.innerHTML = '';
        if (learningsList.length === 0) {
            learnContainer.innerHTML = '<div class="text-center py-6 text-slate-400 text-sm">No learning files found.</div>';
            return;
        }
        
        learningsList.forEach(file => {
            const card = document.createElement('div');
            card.className = "p-4 border border-slate-200 dark:border-slate-800 rounded-2xl flex justify-between items-center bg-white dark:bg-slate-950/20";
            card.innerHTML = `
                <div>
                    <h4 class="font-bold text-slate-800 dark:text-slate-200">${file.name}</h4>
                    <p class="text-[10px] text-slate-400">SHA: ${file.sha.substring(0, 8)}</p>
                </div>
                <button class="btn-edit-learn btn-secondary py-1 px-3.5 text-xs font-semibold" data-path="${file.path}" data-sha="${file.sha}">Edit</button>
            `;
            learnContainer.appendChild(card);
        });

        document.querySelectorAll('.btn-edit-learn').forEach(btn => {
            btn.addEventListener('click', async () => {
                const path = btn.dataset.path;
                const sha = btn.dataset.sha;
                
                btn.disabled = true;
                btn.textContent = 'Loading...';
                try {
                    const res = await apiRequest(path + '?ref=' + gitConfig.branch);
                    const rawText = b64_to_utf8(res.content.replace(/\s/g, ''));
                    const parsed = parseFrontmatter(rawText);
                    
                    learnForm.classList.remove('hidden');
                    document.getElementById('learning-form-title').textContent = 'Edit Learning Entry';
                    document.getElementById('learn-sha').value = sha;
                    document.getElementById('learn-old-path').value = path;
                    document.getElementById('learn-slug').value = path.replace('src/content/learning/', '').replace('.md', '');
                    document.getElementById('learn-date').value = parsed.data.date || '';
                    document.getElementById('learn-title').value = parsed.data.title || '';
                    document.getElementById('learn-category').value = parsed.data.category || '';
                    
                    const isADR = parsed.data.isADR === 'true' || parsed.data.isADR === true;
                    document.getElementById('learn-isADR').checked = isADR;
                    adrStatusDropdown.disabled = !isADR;
                    document.getElementById('learn-adrStatus').value = parsed.data.adrStatus || '';
                    
                    document.getElementById('learn-tags').value = (parsed.data.tags || []).join(', ');
                    document.getElementById('learn-content').value = parsed.body.trim();
                    
                    document.getElementById('btn-delete-learning').classList.remove('hidden');
                    learnForm.scrollIntoView({ behavior: 'smooth' });
                } catch (err) {
                    alert('Failed to load file: ' + err.message);
                } finally {
                    btn.disabled = false;
                    btn.textContent = 'Edit';
                }
            });
        });
    }

    loadLearnBtn.addEventListener('click', async () => {
        loadLearnBtn.disabled = true;
        loadLearnBtn.textContent = 'Loading...';
        try {
            const res = await apiRequest('src/content/learning?ref=' + gitConfig.branch);
            learningsList = res.filter(item => item.name.endsWith('.md'));
            renderLearningsList();
            
            learnPrompt.classList.add('hidden');
            createLearnBtn.classList.remove('hidden');
        } catch (err) {
            alert('Failed to load learnings directory: ' + err.message);
        } finally {
            loadLearnBtn.disabled = false;
            loadLearnBtn.textContent = 'Load Learnings';
        }
    });

    createLearnBtn.addEventListener('click', () => {
        learnForm.classList.remove('hidden');
        document.getElementById('learning-form-title').textContent = 'Create Learning Entry';
        document.getElementById('learn-sha').value = '';
        document.getElementById('learn-old-path').value = '';
        document.getElementById('learn-slug').value = '';
        document.getElementById('learn-date').value = new Date().toISOString().split('T')[0];
        document.getElementById('learn-title').value = '';
        document.getElementById('learn-category').value = '';
        document.getElementById('learn-isADR').checked = false;
        adrStatusDropdown.disabled = true;
        document.getElementById('learn-adrStatus').value = '';
        document.getElementById('learn-tags').value = '';
        document.getElementById('learn-content').value = '';
        
        document.getElementById('btn-delete-learning').classList.add('hidden');
    });

    document.getElementById('btn-cancel-learning').addEventListener('click', () => {
        learnForm.classList.add('hidden');
    });

    learnForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const submitBtn = learnForm.querySelector('button[type="submit"]');
        submitBtn.disabled = true;
        submitBtn.textContent = 'Publishing...';
        
        const slug = document.getElementById('learn-slug').value.trim();
        const sha = document.getElementById('learn-sha').value;
        const oldPath = document.getElementById('learn-old-path').value;
        const newPath = `src/content/learning/${slug}.md`;
        
        const isADR = document.getElementById('learn-isADR').checked;
        
        try {
            const data = {
                title: document.getElementById('learn-title').value.trim(),
                date: document.getElementById('learn-date').value,
                category: document.getElementById('learn-category').value.trim(),
                tags: document.getElementById('learn-tags').value.split(',').map(s => s.trim()).filter(Boolean),
                isADR: isADR,
                adrStatus: isADR ? document.getElementById('learn-adrStatus').value : undefined
            };
            const body = document.getElementById('learn-content').value;
            const fullMarkdown = buildLearningFrontmatter(data, body);
            
            if (oldPath && oldPath !== newPath) {
                await apiRequest(oldPath, {
                    method: 'DELETE',
                    body: JSON.stringify({
                        message: `cms: delete renamed learning entry (${slug})`,
                        sha: sha,
                        branch: gitConfig.branch
                    })
                });
                const res = await apiRequest(newPath, {
                    method: 'PUT',
                    body: JSON.stringify({
                        message: `cms: publish renamed learning entry (${slug})`,
                        content: utf8_to_b64(fullMarkdown),
                        branch: gitConfig.branch
                    })
                });
            } else {
                const res = await apiRequest(newPath, {
                    method: 'PUT',
                    body: JSON.stringify({
                        message: `cms: publish learning entry (${slug})`,
                        content: utf8_to_b64(fullMarkdown),
                        sha: sha || undefined,
                        branch: gitConfig.branch
                    })
                });
            }
            
            alert('Learning entry published successfully!');
            learnForm.classList.add('hidden');
            loadLearnBtn.click();
        } catch (err) {
            alert('Publish failed: ' + err.message);
        } finally {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Publish to Git';
        }
    });

    document.getElementById('btn-delete-learning').addEventListener('click', async () => {
        const sha = document.getElementById('learn-sha').value;
        const path = document.getElementById('learn-old-path').value;
        const slug = document.getElementById('learn-slug').value;
        
        if (!confirm('Are you sure you want to delete this learning entry?')) return;
        
        const deleteBtn = document.getElementById('btn-delete-learning');
        deleteBtn.disabled = true;
        deleteBtn.textContent = 'Deleting...';
        
        try {
            await apiRequest(path, {
                method: 'DELETE',
                body: JSON.stringify({
                    message: `cms: delete learning entry (${slug})`,
                    sha: sha,
                    branch: gitConfig.branch
                })
            });
            alert('Learning entry deleted successfully!');
            learnForm.classList.add('hidden');
            loadLearnBtn.click();
        } catch (err) {
            alert('Delete failed: ' + err.message);
        } finally {
            deleteBtn.disabled = false;
            deleteBtn.textContent = 'Delete Entry';
        }
    });


    // Initialize
    loadGitConfig();
</script>
