        blogPreviewContainer.classList.remove('hidden');
        
        const mdText = document.getElementById('blog-content').value;
        blogPreviewContainer.innerHTML = typeof marked !== 'undefined' ? marked.parse(mdText) : mdText;
    });

    function parseFrontmatter(text) {
        const match = text.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
        if (!match) return { data: {}, body: text };
        
        const rawYaml = match[1];
        const body = match[2];
        const data = {};
        
        rawYaml.split('\n').forEach(line => {
            const idx = line.indexOf(':');
            if (idx > -1) {
                const k = line.substring(0, idx).trim();
                let v = line.substring(idx + 1).trim();
                if (v.startsWith('"') && v.endsWith('"')) v = v.slice(1, -1);
                if (v.startsWith('[') && v.endsWith(']')) {
                    v = v.slice(1, -1).split(',').map(s => s.trim().replace(/^['"]|['"]$/g, '')).filter(Boolean);
                }
                data[k] = v;
            }
        });
        
        return { data, body };
    }

    function buildFrontmatter(data, body) {
        let yaml = '---\n';
        yaml += `title: "${data.title}"\n`;
        yaml += `description: "${data.description}"\n`;
        yaml += `pubDate: "${data.pubDate}"\n`;
        yaml += `author: "${data.author || 'Aunmoy Dey Tanmoy'}"\n`;
        yaml += `tags: [${data.tags.map(t => `"${t}"`).join(', ')}]\n`;
        yaml += `image: "/blog-assets/${data.slug}.jpg"\n`;
        yaml += '---\n\n';
        yaml += body;
        return yaml;
    }

