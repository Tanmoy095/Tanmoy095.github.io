---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<MainLayout title={post.data.title} description={post.data.description}>
    <div class="py-6 max-w-3xl mx-auto">
        <!-- Back Link -->
        <a href="/blog" class="inline-flex items-center gap-2 text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 font-semibold text-sm uppercase tracking-wider mb-8 transition-colors duration-200">
            <span>←</span> Back to Blog
        </a>

        <!-- Article Header -->
        <header class="mb-10 pb-8 border-b border-slate-200/50 dark:border-slate-800/50">
            <div class="flex items-center gap-4 text-xs text-slate-400 mb-4">
                <span>Published on {new Date(post.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                <span>•</span>
                <span>By {post.data.author}</span>
            </div>
            
            <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-slate-900 dark:text-slate-100 mb-6 leading-tight">
                {post.data.title}
            </h1>
            
            <!-- Tags -->
            <div class="flex flex-wrap gap-2">
                {post.data.tags.map(tag => (
                    <span class="bg-indigo-50 dark:bg-indigo-950/50 text-indigo-600 dark:text-indigo-400 text-xs px-3 py-1 rounded-md font-semibold border border-indigo-100/30 dark:border-indigo-900/30">
                        {tag}
                    </span>
                ))}
            </div>
        </header>

        <!-- Markdown Body -->
        <article class="markdown-body">
            <Content />
        </article>
    </div>
</MainLayout>

<style is:global>
    /* Premium Markdown Typography Styles */
    .markdown-body {
        font-size: 1.05rem;
        line-height: 1.8;
        color: #334155; /* slate-700 */
    }
    .dark .markdown-body {
        color: #cbd5e1; /* slate-300 */
    }
    
    .markdown-body h1, 
    .markdown-body h2, 
    .markdown-body h3, 
    .markdown-body h4 {
        color: #0f172a; /* slate-900 */
        font-weight: 800;
        letter-spacing: -0.025em;
        margin-top: 2.25rem;
        margin-bottom: 1rem;
        font-family: 'Outfit', sans-serif;
    }
    .dark .markdown-body h1, 
    .dark .markdown-body h2, 
    .dark .markdown-body h3, 
    .dark .markdown-body h4 {
        color: #f8fafc; /* slate-50 */
    }
    
    .markdown-body h1 { font-size: 2.25rem; }
    .markdown-body h2 { font-size: 1.75rem; border-b: 1px solid rgba(226, 232, 240, 0.4); padding-bottom: 0.5rem; }
    .markdown-body h3 { font-size: 1.35rem; }
    .markdown-body h4 { font-size: 1.15rem; }
    
    .markdown-body p {
        margin-top: 0;
        margin-bottom: 1.5rem;
    }
    
    /* Code styling */
    .markdown-body pre {
        background-color: #0f172a; /* slate-900 */
        color: #f8fafc;
        border-radius: 1rem;
        padding: 1.25rem;
        margin: 1.5rem 0;
        overflow-x: auto;
        border: 1px solid rgba(255, 255, 255, 0.05);
        font-size: 0.9rem;
        line-height: 1.6;
    }
    .markdown-body code {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 0.9em;
        background-color: rgba(99, 102, 241, 0.1); /* light indigo */
        color: #4f46e5;
        padding: 0.15em 0.4em;
        border-radius: 0.375em;
    }
    .dark .markdown-body code {
        background-color: rgba(99, 102, 241, 0.2);
        color: #c7d2fe;
    }
    .markdown-body pre code {
        background-color: transparent;
        color: inherit;
        padding: 0;
        font-size: inherit;
        border-radius: 0;
    }
    
    /* Lists styling */
    .markdown-body ul, 
    .markdown-body ol {
        margin-top: 0;
        margin-bottom: 1.5rem;
        padding-left: 1.5rem;
    }
    .markdown-body ul { list-style-type: disc; }
    .markdown-body ol { list-style-type: decimal; }
    .markdown-body li { margin-bottom: 0.5rem; }
    
    /* Tables styling */
    .markdown-body table {
        width: 100%;
        border-collapse: collapse;
        margin: 2rem 0;
        font-size: 0.95rem;
    }
    .markdown-body th, 
    .markdown-body td {
        padding: 0.75rem 1rem;
        border-bottom: 1px solid #e2e8f0;
        text-align: left;
    }
    .dark .markdown-body th, 
    .dark .markdown-body td {
        border-bottom: 1px solid #1e293b;
    }
    .markdown-body th {
        font-weight: 700;
        background-color: #f1f5f9;
        color: #0f172a;
    }
    .dark .markdown-body th {
        background-color: #0f172a;
        color: #f8fafc;
    }
    
    /* Blockquotes styling */
    .markdown-body blockquote {
        margin: 1.5rem 0;
        padding: 0.5rem 0 0.5rem 1.25rem;
        border-left: 4px solid #6366f1;
        background-color: rgba(99, 102, 241, 0.05);
        border-radius: 0 0.5rem 0.5rem 0;
        font-style: italic;
    }
    .dark .markdown-body blockquote {
        background-color: rgba(99, 102, 241, 0.1);
    }
</style>
